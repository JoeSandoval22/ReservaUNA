<AnchorPane prefHeight="623.0" prefWidth="889.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.reservauna.controller.AdministratorGUI">
