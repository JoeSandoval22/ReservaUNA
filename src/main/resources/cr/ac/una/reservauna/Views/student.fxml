<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<AnchorPane prefHeight="400.0" prefWidth="600.0"
    xmlns="http://javafx.com/javafx/26"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="cr.ac.una.reservauna.controller.StudentGUI">
  <children>
    <Label layoutX="6.0" layoutY="5.0" text="ReservaUNA — "/>
    <Label fx:id="LabelNombre" layoutX="120.0" layoutY="5.0" text=""/>
    <Label layoutX="230.0" layoutY="5.0" text=" | "/>
    <Label fx:id="LabelCorreo" layoutX="245.0" layoutY="5.0" text=""/>
    <HBox layoutY="23.0" prefHeight="25.0" prefWidth="600.0">
      <children>
        <Button text="Archivo" onAction="#btnIngresarArchivo"/>
        <Button text="Reservas" onAction="#btnIngresarReservas"/>
        <Button text="Ayuda" onAction="#btnIngresarAyuda"/>
      </children>
    </HBox>
    <HBox layoutY="49.0" prefHeight="50.0" prefWidth="600.0">
      <children>
        <Button fx:id="btnNuevaReserva" text="Nueva reserva"
                onAction="#btnIngresarNuevaReserva" prefWidth="120.0">
          <font><Font size="14.0"/></font>
        </Button>
        <Button fx:id="btnMisReservas" text="Mis reservas"
                onAction="#btnIngresarMisReservas" prefWidth="110.0">
          <font><Font size="14.0"/></font>
        </Button>
        <Button text="Calendario" onAction="#btnIngresarCalendario"/>
        <Label text="  Usuario: "/>
        <Label fx:id="LabelCorreoBar" prefWidth="130.0" text=""/>
        <Button fx:id="btnCerrarSesion" text="Cerrar sesión"
                onAction="#btnRegresarInicio"/>
      </children>
    </HBox>

    <Label layoutX="20.0" layoutY="108.0" text="Reservas Activas"
           style="-fx-font-size:10px;"/>
    <Label fx:id="LabelReservasActivas" layoutX="30.0" layoutY="122.0"
           style="-fx-font-size:20px;-fx-font-weight:bold;" text="0"/>

    <Label layoutX="160.0" layoutY="108.0" text="Pendientes"
           style="-fx-font-size:10px;"/>
    <Label fx:id="LabelPendientes" layoutX="175.0" layoutY="122.0"
           style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#7a5000;" text="0"/>

    <Label layoutX="300.0" layoutY="108.0" text="Recursos Disponibles"
           style="-fx-font-size:10px;"/>
    <Label fx:id="LabelRecursosDisponible" layoutX="320.0" layoutY="122.0"
           style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#1a5c2a;" text="0"/>

    <Label layoutX="460.0" layoutY="108.0" text="Cupo Restante"
           style="-fx-font-size:10px;"/>
    <Label fx:id="LabelCupoRestante" layoutX="475.0" layoutY="122.0"
           style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#7a1a1a;" text="0"/>

    <TableView fx:id="TablaReservas" layoutX="14.0" layoutY="155.0"
               prefHeight="185.0" prefWidth="340.0">
      <columns>
        <TableColumn fx:id="colRecurso" text="Recurso" prefWidth="113.0"/>
        <TableColumn fx:id="colFecha"   text="Fecha"   prefWidth="113.0"/>
        <TableColumn fx:id="colEstado"  text="Estado"  prefWidth="113.0"/>
      </columns>
    </TableView>

    <Label layoutX="370.0" layoutY="155.0" text="Accesos rápidos"
           style="-fx-font-weight:bold;"/>
    <VBox layoutX="360.0" layoutY="175.0" prefWidth="230.0" spacing="6.0">
      <children>
        <Button fx:id="btnNuevaReserva2" text="+ Nueva reserva"
                onAction="#btnIngresarNuevaReserva2" prefWidth="220.0"/>
        <Button fx:id="btnVerCalendario" text="Ver calendario"
                onAction="#btnIngresarVerCalendario" prefWidth="220.0"/>
        <Button fx:id="btnMisReservas2" text="Mis reservas"
                onAction="#btnIngresarMisReservas2" prefWidth="220.0"/>
      </children>
    </VBox>
  </children>
</AnchorPane>