<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="548.0" prefWidth="881.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.reservauna.controller.LogController">
  <children>
    <Label layoutX="14.0" layoutY="14.0" style="-fx-font-size:16px;-fx-font-weight:bold;" text="Gestor de bitácoras" />
    <TableView fx:id="logsList" layoutX="38.0" layoutY="92.0" prefHeight="340.0" prefWidth="772.0">
      <columns>
        <TableColumn fx:id="idColumn" prefWidth="60.0" text="ID" />
        <TableColumn fx:id="reserveIdColumn" prefWidth="80.0" text="ID de reserva" />
        <TableColumn fx:id="userColumn" prefWidth="150.0" text="Reserva de " />
        <TableColumn fx:id="actionColumn" prefWidth="100.0" text="Acción" />
        <TableColumn fx:id="dateColumn" prefWidth="151.199951171875" text="Fecha " />
        <TableColumn fx:id="detailColumn" prefWidth="229.5999755859375" text="Detalle" />
      </columns>
    </TableView>
    <Label fx:id="lblTotal" layoutX="14.0" layoutY="424.0" style="-fx-font-size:11px;-fx-text-fill:#666;" />
      <Button fx:id="backButton" layoutX="792.0" layoutY="27.0" mnemonicParsing="false" onAction="#backToAdminGUI" text="Regresar" />
      <Button fx:id="searchButton" layoutX="230.0" layoutY="53.0" mnemonicParsing="false" onAction="#searchLog" text="Buscar" />
      <Button fx:id="showButton" layoutX="326.0" layoutY="53.0" mnemonicParsing="false" onAction="#showLogs" text="Mostrar bitácoras" />
      <TextField fx:id="idText" layoutX="38.0" layoutY="53.0" promptText="ID de bitácora" />
  </children>
</AnchorPane>
