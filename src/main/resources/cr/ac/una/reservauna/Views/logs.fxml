<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<AnchorPane prefHeight="460.0" prefWidth="800.0"
    xmlns="http://javafx.com/javafx/26"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="cr.ac.una.reservauna.controller.LogController">
  <children>
    <Label layoutX="14.0" layoutY="14.0" text="Bitácora — LOG_TABLE"
           style="-fx-font-size:16px;-fx-font-weight:bold;"/>
    <HBox layoutX="14.0" layoutY="42.0" spacing="8.0">
      <ComboBox fx:id="cmbFiltroAccion" prefWidth="120.0"/>
      <TextField fx:id="txtBuscarUsuario" promptText="Buscar usuario..." prefWidth="160.0"/>
      <DatePicker fx:id="dpInicio" promptText="Desde" prefWidth="130.0"/>
      <DatePicker fx:id="dpFin" promptText="Hasta" prefWidth="130.0"/>
      <Button fx:id="btnFiltrar" text="Filtrar" onAction="#BtnFiltrar"/>
      <Button fx:id="btnLimpiar" text="Limpiar" onAction="#BtnLimpiar"/>
      <Button fx:id="btnRegresar" text="Regresar" onAction="#BtnRegresar"/>
    </HBox>
    <TableView fx:id="tblLogs" layoutX="14.0" layoutY="76.0"
               prefHeight="340.0" prefWidth="772.0">
      <columns>
        <TableColumn fx:id="colLogId" text="log_id" prefWidth="60.0"/>
        <TableColumn fx:id="colReservaId" text="reserve_id" prefWidth="80.0"/>
        <TableColumn fx:id="colUsuario" text="user_name" prefWidth="150.0"/>
        <TableColumn fx:id="colAccion" text="action" prefWidth="100.0"/>
        <TableColumn fx:id="colFecha" text="log_date" prefWidth="130.0"/>
        <TableColumn fx:id="colDetalle" text="detail" prefWidth="250.0"/>
      </columns>
    </TableView>
    <Label fx:id="lblTotal" layoutX="14.0" layoutY="424.0"
           style="-fx-font-size:11px;-fx-text-fill:#666;"/>
  </children>
</AnchorPane>