<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<AnchorPane prefHeight="560.0" prefWidth="750.0"
    xmlns="http://javafx.com/javafx/26"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="cr.ac.una.reservauna.controller.HandleUserController">
  <children>
    <Label layoutX="14.0" layoutY="14.0" text="Gestión de Usuarios"
           style="-fx-font-size:16px;-fx-font-weight:bold;"/>
    <HBox layoutX="14.0" layoutY="42.0" spacing="8.0">
      <TextField fx:id="txtBuscar" promptText="Buscar nombre o correo..."
                 prefWidth="190.0"/>
      <ComboBox fx:id="cmbFiltroRol"    prefWidth="140.0"/>
      <ComboBox fx:id="cmbFiltroEstado" prefWidth="110.0"/>
      <Button text="Buscar" onAction="#BtnBuscar"/>
      <Button fx:id="btnNuevo" text="+ Nuevo usuario" onAction="#BtnNuevo"
              style="-fx-background-color:#2a902a;-fx-text-fill:white;"/>
      <Button fx:id="btnRegresar" text="Regresar" onAction="#BtnRegresar"/>
    </HBox>
    <TableView fx:id="tblUsuarios" layoutX="14.0" layoutY="76.0"
               prefHeight="210.0" prefWidth="722.0">
      <columns>
        <TableColumn fx:id="colId"      text="user_id"      prefWidth="60.0"/>
        <TableColumn fx:id="colNombre"  text="user_name"    prefWidth="160.0"/>
        <TableColumn fx:id="colCorreo"  text="user_mail"    prefWidth="180.0"/>
        <TableColumn fx:id="colRol"     text="role_name"    prefWidth="130.0"/>
        <TableColumn fx:id="colMax"     text="max_reserves" prefWidth="90.0"/>
        <TableColumn fx:id="colEstado"  text="user_state"   prefWidth="100.0"/>
      </columns>
    </TableView>
    <Label layoutX="14.0" layoutY="296.0" text="Detalle del usuario"
           style="-fx-font-size:13px;-fx-font-weight:bold;"/>
    <HBox layoutX="14.0" layoutY="316.0" spacing="14.0">
      <VBox spacing="7.0" prefWidth="340.0">
        <Label text="user_name *"/>
        <TextField fx:id="txtNombre" prefWidth="320.0"/>
        <Label text="user_mail *"/>
        <TextField fx:id="txtCorreo" prefWidth="320.0"/>
      </VBox>
      <VBox spacing="7.0" prefWidth="340.0">
        <Label text="role_id — Rol *"/>
        <ComboBox fx:id="cmbRol" prefWidth="320.0"/>
        <Label text="user_state *"/>
        <ComboBox fx:id="cmbEstado" prefWidth="320.0"/>
      </VBox>
    </HBox>
    <HBox layoutX="14.0" layoutY="430.0" spacing="8.0">
      <Button fx:id="btnGuardar"   text="Guardar" onAction="#BtnGuardar"
              style="-fx-background-color:#2a70b0;-fx-text-fill:white;" prefWidth="100.0"/>
      <Button fx:id="btnInactivar" text="Inactivar" onAction="#BtnInactivar"
              style="-fx-background-color:#b03030;-fx-text-fill:white;" prefWidth="100.0"/>
      <Button fx:id="btnLimpiar"   text="Limpiar" onAction="#BtnLimpiar" prefWidth="80.0"/>
    </HBox>
    <Label fx:id="lblMensaje" layoutX="14.0" layoutY="466.0"
           style="-fx-font-size:11px;" text=""/>
  </children>
</AnchorPane>