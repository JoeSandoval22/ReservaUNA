<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<AnchorPane prefHeight="420.0" prefWidth="420.0"
    xmlns="http://javafx.com/javafx/26"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="cr.ac.una.reservauna.controller.SingUpController">
  <children>
    <Label layoutX="14.0" layoutY="14.0" text="Registrar usuario"
           style="-fx-font-size:16px;-fx-font-weight:bold;"/>
    <VBox layoutX="14.0" layoutY="44.0" spacing="8.0" prefWidth="392.0">
      <Label text="user_name *"/>
      <TextField fx:id="txtNombre" prefWidth="380.0"
                 promptText="Nombre completo"/>
      <Label text="user_mail *"/>
      <TextField fx:id="txtCorreo" prefWidth="380.0"
                 promptText="usuario@una.ac.cr"/>
      <Label text="Contraseña *"/>
      <PasswordField fx:id="txtContrasena" prefWidth="380.0"/>
      <Label text="role_id — Rol *"/>
      <ComboBox fx:id="cmbRol" prefWidth="380.0"/>
      <Label text="user_state *"/>
      <ComboBox fx:id="cmbEstado" prefWidth="380.0"/>
    </VBox>
    <HBox layoutX="14.0" layoutY="330.0" spacing="8.0">
      <Button fx:id="btnGuardar"   text="Guardar" onAction="#BtnGuardar"
              style="-fx-background-color:#2a70b0;-fx-text-fill:white;" prefWidth="120.0"/>
      <Button fx:id="btnLimpiar"   text="Limpiar" onAction="#BtnLimpiar" prefWidth="80.0"/>
      <Button fx:id="btnRegresar"  text="Regresar" onAction="#BtnRegresar" prefWidth="80.0"/>
    </HBox>
    <Label fx:id="lblMensaje" layoutX="14.0" layoutY="368.0"
           style="-fx-font-size:11px;" text=""/>
  </children>
</AnchorPane>