<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="420.0" prefWidth="420.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.reservauna.controller.SingUpController">
  <children>
    <Label layoutX="14.0" layoutY="14.0" style="-fx-font-size:16px;-fx-font-weight:bold;" text="Registrar usuario" />
    <VBox layoutX="14.0" layoutY="44.0" prefWidth="392.0" spacing="8.0">
      <Label text="user_name *" />
      <TextField fx:id="txtNombre" prefWidth="380.0" promptText="Nombre completo" />
      <Label text="user_mail *" />
      <TextField fx:id="txtCorreo" prefWidth="380.0" promptText="usuario@una.ac.cr" />
      <Label text="Contraseña *" />
      <PasswordField fx:id="txtContrasena" prefWidth="380.0" />
      <Label text="role_id — Rol *" />
         <TextField fx:id="roleField" promptText="1-ADMI, 2-ENCARGADO, 3-PROF. 4-EST." />
      <Label text="user_state *" />
         <TextField fx:id="userState" promptText="ACTIVO/INACTIVO" />
    </VBox>
    <HBox layoutX="14.0" layoutY="330.0" spacing="8.0">
      <Button fx:id="btnGuardar" onAction="#BtnGuardar" prefWidth="120.0" style="-fx-background-color:#2a70b0;-fx-text-fill:white;" text="Guardar" />
      <Button fx:id="btnLimpiar" onAction="#BtnLimpiar" prefWidth="80.0" text="Limpiar" />
      <Button fx:id="btnRegresar" onAction="#BtnRegresar" prefWidth="80.0" text="Regresar" />
    </HBox>
    <Label fx:id="lblMensaje" layoutX="14.0" layoutY="368.0" style="-fx-font-size:11px;" text="" />
      <BorderPane prefHeight="200.0" prefWidth="200.0" />
  </children>
</AnchorPane>
