<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="420.0" prefWidth="420.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.reservauna.controller.SingUpController">
  <children>
    <Label layoutX="14.0" layoutY="14.0" style="-fx-font-size:16px;-fx-font-weight:bold;" text="Registrar usuario" />
    <VBox layoutX="14.0" layoutY="44.0" prefWidth="392.0" spacing="8.0">
      <Label text="user_name *" />
      <TextField fx:id="nameText" prefWidth="380.0" promptText="Nombre completo" />
      <Label text="user_mail *" />
      <TextField fx:id="emailText" prefWidth="380.0" promptText="usuario@una.ac.cr" />
      <Label text="Contraseña *" />
      <PasswordField fx:id="passwordText" prefWidth="380.0" />
      <Label text="role_id — Rol *" />
         <ComboBox fx:id="roleCombo" prefWidth="150.0" />
      <Label text="user_state *" />
         <ComboBox fx:id="userStateCombo" layoutX="10.0" layoutY="213.0" prefWidth="150.0" />
    </VBox>
    <HBox layoutX="14.0" layoutY="330.0" spacing="8.0" />
    <Label fx:id="lblMensaje" layoutX="14.0" layoutY="368.0" style="-fx-font-size:11px;" text="" />
   <Button fx:id="backButton" layoutX="318.0" layoutY="367.0" onAction="#backToLogin" prefWidth="80.0" text="Regresar" />
   <Button fx:id="clearButton" layoutX="183.0" layoutY="367.0" onAction="#clearFields" prefWidth="80.0" text="Limpiar" />
   <Button fx:id="saveButton" layoutX="18.0" layoutY="367.0" onAction="#addUser" prefWidth="120.0" style="-fx-background-color:#2a70b0;-fx-text-fill:white;" text="Guardar" />
  </children>
</AnchorPane>
