<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<AnchorPane prefHeight="460.0" prefWidth="680.0"
    xmlns="http://javafx.com/javafx/26"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="cr.ac.una.reservauna.controller.ReserveItemController">
  <children>
    <Label layoutX="14.0" layoutY="14.0" text="Items de Reserva (RESERVE_ITEM)"
           style="-fx-font-size:16px;-fx-font-weight:bold;"/>
    <Label fx:id="lblReservaPadre" layoutX="14.0" layoutY="40.0"
           style="-fx-text-fill:#666;" text=""/>
    <TableView fx:id="tblItems" layoutX="14.0" layoutY="58.0"
               prefHeight="170.0" prefWidth="652.0">
      <columns>
        <TableColumn fx:id="colItemId"  text="reserve_item_id" prefWidth="110.0"/>
        <TableColumn fx:id="colRecurso" text="resource_name"   prefWidth="180.0"/>
        <TableColumn fx:id="colInicio"  text="start_date"      prefWidth="170.0"/>
        <TableColumn fx:id="colFin"     text="end_date"        prefWidth="170.0"/>
      </columns>
    </TableView>
    <Label layoutX="14.0" layoutY="238.0" text="Agregar item a esta reserva"
           style="-fx-font-size:13px;-fx-font-weight:bold;"/>
    <HBox layoutX="14.0" layoutY="260.0" spacing="14.0">
      <VBox spacing="7.0" prefWidth="310.0">
        <Label text="resource_id — Recurso *"/>
        <ComboBox fx:id="cmbRecurso" prefWidth="290.0"/>
      </VBox>
      <VBox spacing="7.0" prefWidth="310.0">
        <Label text="start_date *"/>
        <HBox spacing="6.0">
          <DatePicker fx:id="dpInicio"       prefWidth="185.0"/>
          <TextField  fx:id="txtHoraInicio"  promptText="HH:mm" prefWidth="80.0"/>
        </HBox>
        <Label text="end_date *"/>
        <HBox spacing="6.0">
          <DatePicker fx:id="dpFin"         prefWidth="185.0"/>
          <TextField  fx:id="txtHoraFin"    promptText="HH:mm" prefWidth="80.0"/>
        </HBox>
      </VBox>
    </HBox>
    <HBox layoutX="14.0" layoutY="380.0" spacing="8.0">
      <Button fx:id="btnAgregar"  text="Agregar item" onAction="#BtnAgregar"
              style="-fx-background-color:#2a70b0;-fx-text-fill:white;" prefWidth="120.0"/>
      <Button fx:id="btnEliminar" text="Eliminar item" onAction="#BtnEliminar"
              style="-fx-background-color:#b03030;-fx-text-fill:white;" prefWidth="120.0"/>
      <Button fx:id="btnRegresar" text="Regresar" onAction="#BtnRegresar" prefWidth="80.0"/>
    </HBox>
    <Label fx:id="lblMensaje" layoutX="14.0" layoutY="416.0"
           style="-fx-font-size:11px;" text=""/>
  </children>
</AnchorPane>