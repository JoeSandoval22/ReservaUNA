<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<AnchorPane prefHeight="620.0" prefWidth="800.0"
    xmlns="http://javafx.com/javafx/26"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="cr.ac.una.reservauna.controller.ReserveController">
  <children>
    <Label layoutX="14.0" layoutY="14.0" text="Gestión de Reservas"
           style="-fx-font-size:16px;-fx-font-weight:bold;"/>
    <HBox layoutX="14.0" layoutY="40.0" spacing="8.0">
      <ComboBox fx:id="cmbFiltroEstado" promptText="Estado" prefWidth="120.0"/>
      <DatePicker fx:id="dpFechaInicio" promptText="Desde" prefWidth="140.0"/>
      <DatePicker fx:id="dpFechaFin" promptText="Hasta" prefWidth="140.0"/>
      <Button text="Buscar" onAction="#BtnBuscar"/>
      <Button text="+ Nueva reserva" onAction="#BtnLimpiar"
              style="-fx-background-color:#2a70b0;-fx-text-fill:white;"/>
    </HBox>
    <TableView fx:id="tblReservas" layoutX="14.0" layoutY="75.0"
               prefHeight="180.0" prefWidth="772.0">
      <columns>
        <TableColumn fx:id="colId" text="ID" prefWidth="50.0"/>
        <TableColumn fx:id="colRecurso" text="Recurso" prefWidth="150.0"/>
        <TableColumn fx:id="colInicio" text="start_date" prefWidth="120.0"/>
        <TableColumn fx:id="colFin" text="end_date" prefWidth="120.0"/>
        <TableColumn fx:id="colMotivo" text="reason" prefWidth="200.0"/>
        <TableColumn fx:id="colEstado" text="Estado" prefWidth="120.0"/>
      </columns>
    </TableView>
    <Label layoutX="14.0" layoutY="265.0" text="Nueva / editar reserva"
           style="-fx-font-size:13px;-fx-font-weight:bold;"/>
    <VBox layoutX="14.0" layoutY="285.0" prefWidth="380.0" spacing="6.0">
      <Label text="resource_id — Recurso *"/>
      <ComboBox fx:id="cmbRecurso" prefWidth="360.0"/>
      <Label text="start_date"/>
      <HBox spacing="6.0">
        <DatePicker fx:id="dpInicio" prefWidth="200.0"/>
        <TextField fx:id="txtHoraInicio" promptText="HH:mm" prefWidth="90.0"/>
      </HBox>
      <Label text="end_date"/>
      <HBox spacing="6.0">
        <DatePicker fx:id="dpFin" prefWidth="200.0"/>
        <TextField fx:id="txtHoraFin" promptText="HH:mm" prefWidth="90.0"/>
      </HBox>
      <Label text="reason *"/>
      <TextField fx:id="txtMotivo" prefWidth="360.0"/>
      <Label text="reserve_status"/>
      <ComboBox fx:id="cmbEstado" prefWidth="360.0"/>
    </VBox>
    <VBox layoutX="410.0" layoutY="285.0" prefWidth="380.0" spacing="6.0">
      <Label fx:id="lblDisponibilidad" style="-fx-text-fill:green;"/>
      <Button text="Verificar disponibilidad" onAction="#BtnVerificar"
              prefWidth="360.0" style="-fx-background-color:#c07000;-fx-text-fill:white;"/>
      <Label text="Motivo cancelación (si aplica)"/>
      <TextArea fx:id="txtMotivoCancel" prefHeight="70.0" prefWidth="360.0"
                promptText="Motivo de cancelación..."/>
    </VBox>
    <HBox layoutX="14.0" layoutY="510.0" spacing="8.0">
      <Button fx:id="btnGuardar" text="Guardar reserva" onAction="#BtnGuardar"
              style="-fx-background-color:#2a70b0;-fx-text-fill:white;"/>
      <Button fx:id="btnCancelar" text="Cancelar reserva" onAction="#BtnCancelar"
              style="-fx-background-color:#b03030;-fx-text-fill:white;"/>
      <Button fx:id="btnLimpiar" text="Limpiar" onAction="#BtnLimpiar"/>
      <Button fx:id="btnRegresar" text="Regresar" onAction="#BtnRegresar"/>
    </HBox>
    <Label fx:id="lblMensaje" layoutX="14.0" layoutY="545.0"
           style="-fx-font-size:11px;"/>
  </children>
</AnchorPane>