<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="620.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.reservauna.controller.ReserveController">
  <children>
    <Label layoutX="14.0" layoutY="14.0" style="-fx-font-size:16px;-fx-font-weight:bold;" text="Gestión de Reservas" />
    <HBox layoutX="14.0" layoutY="40.0" spacing="8.0">
      <ComboBox fx:id="cmbFiltroEstado" prefWidth="120.0" promptText="Estado" />
      <DatePicker fx:id="dpFechaInicio" prefWidth="140.0" promptText="Desde" />
      <DatePicker fx:id="dpFechaFin" prefWidth="140.0" promptText="Hasta" />
      <Button onAction="#BtnBuscar" text="Buscar" />
      <Button onAction="#BtnLimpiar" style="-fx-background-color:#2a70b0;-fx-text-fill:white;" text="+ Nueva reserva" />
    </HBox>
    <TableView fx:id="tblReservas" layoutX="14.0" layoutY="75.0" prefHeight="180.0" prefWidth="772.0">
      <columns>
        <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
        <TableColumn fx:id="colRecurso" prefWidth="150.0" text="Recurso" />
        <TableColumn fx:id="colInicio" prefWidth="120.0" text="start_date" />
        <TableColumn fx:id="colFin" prefWidth="120.0" text="end_date" />
        <TableColumn fx:id="colMotivo" prefWidth="200.0" text="reason" />
        <TableColumn fx:id="colEstado" prefWidth="120.0" text="Estado" />
      </columns>
    </TableView>
    <Label layoutX="14.0" layoutY="265.0" style="-fx-font-size:13px;-fx-font-weight:bold;" text="Nueva / editar reserva" />
    <VBox layoutX="14.0" layoutY="285.0" prefWidth="380.0" spacing="6.0">
      <Label text="resource_id — Recurso *" />
      <ComboBox fx:id="cmbRecurso" prefWidth="360.0" />
      <Label text="start_date" />
      <HBox spacing="6.0">
        <DatePicker fx:id="dpInicio" prefWidth="200.0" />
        <TextField fx:id="txtHoraInicio" prefWidth="90.0" promptText="HH:mm" />
      </HBox>
      <Label text="end_date" />
      <HBox spacing="6.0">
        <DatePicker fx:id="dpFin" prefWidth="200.0" />
        <TextField fx:id="txtHoraFin" prefWidth="90.0" promptText="HH:mm" />
      </HBox>
      <Label text="reason *" />
      <TextField fx:id="txtMotivo" prefWidth="360.0" />
      <Label text="reserve_status" />
      <ComboBox fx:id="cmbEstado" prefWidth="360.0" />
       <HBox spacing="8.0">
         <Button fx:id="btnGuardar" onAction="#BtnGuardar" style="-fx-background-color:#2a70b0;-fx-text-fill:white;" text="Guardar reserva" />
         <Button fx:id="btnCancelar" onAction="#BtnCancelar" style="-fx-background-color:#b03030;-fx-text-fill:white;" text="Cancelar reserva" />
         <Button fx:id="btnLimpiar" onAction="#BtnLimpiar" text="Limpiar" />
         <Button fx:id="btnRegresar" onAction="#BtnRegresar" text="Regresar" />
       </HBox>
    </VBox>
    <VBox layoutX="410.0" layoutY="285.0" prefWidth="380.0" spacing="6.0">
      <Label fx:id="lblDisponibilidad" style="-fx-text-fill:green;" />
      <Button onAction="#BtnVerificar" prefWidth="360.0" style="-fx-background-color:#c07000;-fx-text-fill:white;" text="Verificar disponibilidad" />
      <Label text="Motivo cancelación (si aplica)" />
      <TextArea fx:id="txtMotivoCancel" prefHeight="70.0" prefWidth="360.0" promptText="Motivo de cancelación..." />
    </VBox>
    <Label fx:id="lblMensaje" layoutX="14.0" layoutY="545.0" style="-fx-font-size:11px;" />
  </children>
</AnchorPane>
