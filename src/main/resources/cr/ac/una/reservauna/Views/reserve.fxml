<AnchorPane prefHeight="689.0" prefWidth="1033.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.reservauna.controller.ReserveController">
  <children>
    <Label layoutX="14.0" layoutY="14.0" prefHeight="26.0" prefWidth="163.0" style="-fx-font-size:16px;-fx-font-weight:bold;" text="Gestión de Reservas">
