        <TableColumn fx:id="userColumn" prefWidth="81.60001373291016" text="Usuario" />
        <TableColumn fx:id="resourceNameColumn" prefWidth="109.5999755859375" text="Recurso" />
        <TableColumn fx:id="startDateColumn" prefWidth="157.60003662109375" text="Fecha de inicio" />
        <TableColumn fx:id="endDateColumn" prefWidth="144.7999267578125" text="Fecha final" />
